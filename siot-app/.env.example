# 이 파일을 .env.local로 복사한 뒤 값을 채우세요. (.env.local은 깃에 안 올라감)
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=

# 시옷플랫폼 연동 (단계 7)
# (dev 오버라이드 전용 — 운영은 자동 생성/등록)
SIOT_GATEWAY_ID=siot-gateway-dev
# 시옷플랫폼이 이 게이트웨이 API를 호출할 때 쓸 Bearer 토큰 (강력한 무작위 값으로)
# (dev 오버라이드 전용 — 운영은 자동 생성/등록)
SIOT_PLATFORM_TOKEN=
SIOT_GATEWAY_VERSION=0.1.0
SIOT_DATA_DIR=.siot-data
